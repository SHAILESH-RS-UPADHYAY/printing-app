{
  "cli": {
    "version": ">= 3.0.0"
  },
  "build": {
    "development": {
      "channel": "development",
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "ios": { "buildType": "simulator" }
    },
    "preview": {
      "channel": "preview",
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "ios": { "buildType": "archive" }
    },
    "production": {
      "channel": "production",
      "distribution": "store",
      "android": { "buildType": "app-bundle" },
      "ios": { "buildType": "archive" }
    }
  }
}
